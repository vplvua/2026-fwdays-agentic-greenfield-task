# Copy to .env for local development (never commit real values — NFR-SEC-04).
# In production (Railway) these are set as service env vars, not files.

# MySQL connection (matches docker-compose.yml defaults)
DATABASE_URL="mysql://servicedesk:servicedesk@localhost:3306/servicedesk"

# API port (NestJS listens here; serves SPA statics in production mode)
PORT=3000

# Optional: absolute path to the built SPA (defaults to the web build output
# bundled next to the api dist — set only when running outside the image)
# WEB_DIST_PATH=/app/web

# --- Auth (S-02, ADR-0004) ---

# HMAC key for OTP code hashes; any long random string. Required.
# Generate for prod: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me"

# SMS delivery: "dev" logs the code instead of sending (no SMS cost);
# "turbosms" sends via TurboSMS and requires TURBOSMS_TOKEN.
# Defaults: dev locally, turbosms in production (prod refuses "dev").
SMS_MODE=dev
# TURBOSMS_TOKEN=
# TURBOSMS_SENDER=Msg

# Session cookie `Secure` flag override; defaults by NODE_ENV
# (on in production, off locally — Safari drops Secure cookies on http://localhost)
# COOKIE_SECURE=true
