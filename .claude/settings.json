{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-format.sh",
            "timeout": 120,
            "statusMessage": "prettier + eslint on edited file"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-verify.sh",
            "timeout": 900,
            "statusMessage": "verify gate (runs on git commit)"
          }
        ]
      }
    ]
  }
}
